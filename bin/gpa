#!/usr/bin/env bash
# Wrapper that invokes the gpa CLI from a source checkout without needing
# `pip install -e .`.
#
# Autodetects the bazel-built Python 3.11 interpreter and the pybind11
# extension `_gpa_core.so` so users don't have to plumb PYTHONPATH /
# GPA_PYTHON manually. Honours an explicit $GPA_PYTHON if set.
#
# Interpreter search order:
#   1. $GPA_PYTHON, if set.
#   2. Default bazel cache: ~/.cache/bazel/_bazel_$USER/.../external/
#      rules_python~~python~python_3_11_<triple>/bin/python3.11.
#   3. $BAZEL_OUTPUT_BASE, if set (short-circuits the `bazel info` call;
#      primarily for tests).
#   4. `bazel info output_base` — honors --output_user_root / --output_base
#      / .bazelrc overrides.
#   5. `python3` fallback + warning.

set -e
here="$(cd "$(dirname "$0")" && pwd)"
root="$(cd "$here/.." && pwd)"

# ---------------------------------------------------------------------------
# 1. Locate `_gpa_core.so` under <repo>/bazel-bin/src/bindings/.
# ---------------------------------------------------------------------------
bindings_dir="$root/bazel-bin/src/bindings"
have_bindings=0
if [ -f "$bindings_dir/_gpa_core.so" ]; then
    have_bindings=1
fi

# ---------------------------------------------------------------------------
# 2. Locate the bazel-managed Python 3.11 interpreter.
#    Default layout:
#        ~/.cache/bazel/_bazel_$USER/.../external/
#            rules_python~~python~python_3_11_<triple>/bin/python3.11
#
#    Custom layouts (e.g. `bazel --output_user_root=/tmp/foo` or
#    `--output_base=/srv/bazel-cache`) break the default path. When the
#    default search misses, we ask bazel itself where output_base lives
#    via `bazel info output_base` and search there. An explicit
#    $BAZEL_OUTPUT_BASE short-circuits the shell-out (used by unit tests).
# ---------------------------------------------------------------------------
_search_rules_python() {
    # $1 = directory to search under. Prints candidate path on success.
    local base="$1"
    [ -d "$base" ] || return 1
    local candidate
    # -maxdepth keeps this fast even with many output bases.
    candidate="$(find "$base" -maxdepth 6 -type d \
                    -name 'rules_python*python_3_11*' 2>/dev/null | head -n1)"
    [ -n "$candidate" ] || return 1
    if [ -x "$candidate/bin/python3.11" ]; then
        printf '%s\n' "$candidate/bin/python3.11"
        return 0
    fi
    if [ -x "$candidate/bin/python3" ]; then
        printf '%s\n' "$candidate/bin/python3"
        return 0
    fi
    return 1
}

detect_bazel_python() {
    local found=""
    # 2a. Default location.
    local bazel_root="${HOME}/.cache/bazel/_bazel_${USER:-$(id -un)}"
    found="$(_search_rules_python "$bazel_root" || true)"
    if [ -n "$found" ]; then printf '%s\n' "$found"; return 0; fi

    # 2b. Explicit override (primarily for unit tests).
    if [ -n "$BAZEL_OUTPUT_BASE" ]; then
        found="$(_search_rules_python "$BAZEL_OUTPUT_BASE" || true)"
        if [ -n "$found" ]; then printf '%s\n' "$found"; return 0; fi
    fi

    # 2c. Ask bazel for its configured output_base. This handles
    #     --output_user_root / --output_base / .bazelrc overrides.
    if command -v bazel >/dev/null 2>&1; then
        local ob
        ob="$(cd "$root" 2>/dev/null && bazel info output_base 2>/dev/null || true)"
        if [ -n "$ob" ] && [ "$ob" != "$bazel_root" ]; then
            found="$(_search_rules_python "$ob" || true)"
            if [ -n "$found" ]; then printf '%s\n' "$found"; return 0; fi
        fi
    fi
    return 1
}

if [ -n "$GPA_PYTHON" ]; then
    py="$GPA_PYTHON"
else
    py="$(detect_bazel_python || true)"
    if [ -z "$py" ]; then
        if [ "$have_bindings" = "1" ]; then
            echo "[gpa] warning: bazel python 3.11 not found; falling back to python3." \
                 "Set GPA_PYTHON to override." >&2
        fi
        py="python3"
    fi
fi

# ---------------------------------------------------------------------------
# 3. Assemble PYTHONPATH. Prepend bindings dir so `import _gpa_core` works.
# ---------------------------------------------------------------------------
pypath="$root/src/python"
if [ "$have_bindings" = "1" ]; then
    pypath="$bindings_dir:$pypath"
else
    echo "[gpa] warning: $bindings_dir/_gpa_core.so not found; native backend will fail." \
         "Build it with 'bazel build //src/bindings:_gpa_core.so'." >&2
fi

export GPA_PYTHON="$py"

# Diagnostic hook used by unit tests (and humans): dump the resolved env and exit 0.
if [ "${GPA_DIAG:-0}" = "1" ]; then
    printf 'GPA_PYTHON=%s\n' "$py"
    printf 'PYTHONPATH=%s\n' "$pypath${PYTHONPATH:+:$PYTHONPATH}"
    printf 'bindings_found=%s\n' "$have_bindings"
    exit 0
fi

PYTHONPATH="$pypath${PYTHONPATH:+:$PYTHONPATH}" exec "$py" -m gpa.cli.main "$@"
